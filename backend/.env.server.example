# Скопируй этот файл в .env на сервере и заполни значения
# cp .env.server.example .env

# Application
NODE_ENV=production
PORT=3000

# JWT Configuration (сгенерируй: openssl rand -hex 32)
JWT_SECRET=ЗАМЕНИ_НА_СЛУЧАЙНУЮ_СТРОКУ_МИНИМУМ_32_СИМВОЛА
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# CORS — укажи IP сервера или * для открытого доступа (для разработки)
ALLOWED_ORIGINS=*

# PostgreSQL — нативная установка на сервере
DB_HOST=localhost
DB_PORT=5432
DB_NAME=primakovapp
DB_USER=primakov
DB_PASSWORD=primakov
