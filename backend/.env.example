# Backend Environment Configuration

# Application
NODE_ENV=development
PORT=3000

# JWT Configuration (REQUIRED - must be at least 32 characters)
JWT_SECRET=your_very_long_and_secure_jwt_secret_key_at_least_32_characters_long
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# CORS Configuration
# Development: localhost allowed by default
# Production: comma-separated list of allowed origins
ALLOWED_ORIGINS=https://primakov-app.ru,https://www.primakov-app.ru

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=primakov_app
DB_USER=postgres
DB_PASSWORD=postgres

# Database Connection Pool Settings (optional)
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000

# Redis Configuration (optional)
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
