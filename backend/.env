# Backend Environment Configuration
NODE_ENV=development
PORT=3000

# JWT Configuration
JWT_SECRET=primakov_app_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Database Configuration
DATABASE_URL=postgres://localhost:5432/primakov_app
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
